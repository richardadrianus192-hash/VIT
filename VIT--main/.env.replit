# .env.replit - Environment variables for Replit

# Database (use SQLite for simplicity)
DATABASE_URL=sqlite+aiosqlite:///vit.db

# Redis (use in-memory fallback)
REDIS_URL=memory://

# API Configuration
API_KEY=replit_dev_key
AUTH_ENABLED=false
LOG_LEVEL=INFO

# Service URLs
ML_SERVICE_URL=http://localhost:8001

# Replit specific
REPLIT_DEPLOYMENT=true
PYTHONPATH=.